# Deployment: Sentinel-SRE Backend Configuration

# --- Server Settings ---
PORT=8000
ALLOWED_ORIGINS=https://your-frontend-vercel-url.vercel.app,http://localhost:3000

# --- Database ---
# For SQLite (local): sqlite:///./incidents.db
# For PostgreSQL (production): postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://user:password@host:port/dbname

# --- AI Engines ---
OPENAI_API_KEY=sk-proj-...
GROQ_API_KEY=gsk_...

# --- ChatOps (Slack) ---
# Set to 'false' in production to use live Slack mode
NEXT_PUBLIC_USE_SIMULATION=false
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...

# --- Telemetry Auth ---
# This must match the 'Authorization: Bearer <token>' used in your Prometheus/Grafana webhooks
TELEMETRY_SECRET_TOKEN=generate-a-secure-random-token-here
